---
import SectionHeader from "@/components/astro/shared/SectionHeader.astro";

const cases = [
    {
        id: 1,
        tag: "AI / OCR",
        t: "AI OCR",
        d: "帳票・請求書・手書き書類の読み取りをLLMと組み合わせて自動化。非定型フォーマットへの対応と既存システムへの統合を実現。",
        stack: "Python · Claude · pgvector",
        href: "/services#ai-ocr",
    },
    {
        id: 2,
        tag: "AI / SEARCH",
        t: "AIベクトル検索",
        d: "キーワードで探せないものを、意図から探せるようにする。EC・求人・不動産など、大量コンテンツを持つサービスの検索体験を刷新。",
        stack: "pgvector · Next.js · Go",
        href: "/services#ai-search",
    },
    {
        id: 3,
        tag: "WEB / SYSTEM",
        t: "業務システム開発",
        d: "Go / Next.js の自社テンプレートをベースに業務システムを構築。管理画面・社内ツール・BtoB向けWebアプリをスピーディーに立ち上げ。",
        stack: "Go · Next.js · AWS",
        href: "/services#business-systems",
    },
];
---

<section id="works" class="bp-section">
    <div class="bp-section-inner">
        <SectionHeader no="04" en="WORKS" jp="導入実績" />

        <div class="works-grid">
            {
                cases.map((c) => (
                    <a href={c.href} class="work-card">
                        <div class="work-body">
                            <div class="work-meta">
                                <span>● {c.tag}</span>
                            </div>
                            <h3>{c.t}</h3>
                            <p>{c.d}</p>
                            <div class="work-stack">stack: {c.stack}</div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .works-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }
    @media (max-width: 900px) {
        .works-grid { grid-template-columns: 1fr; }
    }

    .work-card {
        background: var(--bp-paper-2);
        border: 1.5px solid var(--bp-ink);
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        transition: transform 0.18s ease;
    }
    .work-card:hover {
        transform: translateY(-2px);
        color: inherit;
    }
    .work-card:hover h3 {
        color: var(--bp-blue);
    }

    .work-preview {
        height: 160px;
        background-color: var(--bp-paper);
        border-bottom: 1px solid var(--bp-ink);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .work-preview span {
        font-family: var(--font-mono),serif;
        font-size: 12px;
        color: var(--bp-ink);
        letter-spacing: 0.12em;
        opacity: 0.6;
    }

    .work-body { padding: 22px; }

    .work-meta {
        display: flex;
        justify-content: space-between;
        font-family: var(--font-mono),serif;
        font-size: 10px;
        letter-spacing: 0.14em;
        color: var(--bp-blue);
        margin-bottom: 16px;
    }
    .work-meta .muted { opacity: 0.5; }

    .work-card h3 {
        font-family: var(--font-sans),serif;
        font-size: 22px;
        font-weight: 900;
        color: var(--bp-ink);
        margin: 0 0 10px;
        letter-spacing: -0.015em;
        transition: color 0.15s ease;
    }
    .work-card p {
        font-family: var(--font-sans),serif;
        font-size: 13px;
        line-height: 1.8;
        color: var(--bp-ink-soft);
        margin: 0 0 20px;
    }
    .work-stack {
        padding-top: 14px;
        border-top: 1px dashed var(--bp-border-dash);
        font-family: var(--font-mono),serif;
        font-size: 11px;
        color: var(--bp-muted);
        letter-spacing: 0.06em;
    }
</style>
