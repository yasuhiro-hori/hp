---
import CornerMarks from "@/components/astro/shared/CornerMarks.astro";
import SectionHeader from "@/components/astro/shared/SectionHeader.astro";
import DrawingHeader from "@/components/astro/shared/DrawingHeader.astro";

const companyRows = [
    ["会社名", "株式会社テクシズ / TECSIZ Co., Ltd."],
    ["代表者", "堀 靖弘"],
    ["所在地", "〒105-0013  東京都港区浜松町2-2-15  浜松町ダイヤビル2F"],
    ["事業内容", "システム開発 / ITコンサルティング / AI 活用支援"],
];

const access = [
    { line: "JR山手線・京浜東北線", stn: "浜松町駅", exit: "北口", min: "徒歩2分" },
    { line: "都営大江戸線・浅草線", stn: "大門駅", exit: "B4出口", min: "徒歩1分" },
    { line: "東京モノレール", stn: "浜松町駅", exit: "", min: "徒歩4分" },
];

const values = [
    {
        jp: "現場に立つ",
        en: "On-site",
        d: "机上ではなく、ユーザーの隣で考える。一次情報からしか、本当の課題は見つからない。",
    },
    {
        jp: "早く作って試す",
        en: "Build first",
        d: "議論より動くプロトタイプ。仮説は触ってもらって初めて検証できる。",
    },
    {
        jp: "長く育てる",
        en: "Grow long-term",
        d: "プロジェクトではなくプロダクト。納品で終わらせず、使われ続ける形を一緒に育てる。",
    },
    {
        jp: "AIを当然に使う",
        en: "AI-native",
        d: "最先端の道具を使うことに、ためらわない。生産性とプロダクト性能の両方を底上げする。",
    },
];
---

<section class="bp-section about-hero bp-grid-bg">
    <div class="bp-section-inner">
        <DrawingHeader drawing="04-ABOUT / 会社概要" sheet="04" />
        <h1>
            現場に入り、<br />
            <span class="hl">プロダクト</span>をつくる。
        </h1>
        <p class="about-lead">
            受託でも自社サービスでもない、Forward Deployed Engineer
            として顧客の現場に入り込み、AI を活用して SaaS を共創する開発スタジオ。スピードと現場理解の深さで、使われるプロダクトを作る。
        </p>
    </div>
</section>

<section class="bp-section">
    <div class="bp-section-inner">
        <SectionHeader no="01" en="COMPANY DATA" jp="会社情報" />

        <div class="about-grid">
            <div class="bp-card-bordered">
                <CornerMarks />
                <div class="bp-label-small" style="margin-bottom: 24px">
                    株式会社テクシズ
                </div>
                <table class="spec-table">
                    <tbody>
                        {
                            companyRows.map(([ ja, v]) => (
                                <tr>
                                    <td class="ja">{ja}</td>
                                    <td>{v}</td>
                                </tr>
                            ))
                        }
                    </tbody>
                </table>
            </div>

            <div class="bp-card-bordered">
                <CornerMarks />
                <div class="bp-label-small" style="margin-bottom: 20px">
                    アクセス
                </div>
                {
                    access.map((a, i) => (
                        <div class="access-row" data-first={i === 0} data-last={i === access.length - 1}>
                            <div class="access-no">{i + 1}</div>
                            <div>
                                <div class="access-line">{a.line}</div>
                                <div class="access-stn">
                                    {a.stn}{" "}
                                    <span class="access-exit">{a.exit}</span>
                                </div>
                            </div>
                            <div class="access-min">{a.min}</div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<section class="bp-section">
    <div class="bp-section-inner">
        <div class="map-container">
            <CornerMarks />
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3241.892040529851!2d139.7522695767426!3d35.65523067259469!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60188bb66eddac03%3A0xd9b780ada67af5ee!2z5rWc5p2-55S644OA44Kk44Ok44OP44Kk44OE!5e0!3m2!1sja!2sjp!4v1740611500000!5m2!1sja!2sjp"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="株式会社テクシズ 所在地"
            ></iframe>
            <div class="map-cta">
                <a
                    href="https://www.google.co.jp/maps/place/%E6%B5%9C%E6%9D%BE%E7%94%BA%E3%83%80%E3%82%A4%E3%83%A4%E3%83%8F%E3%82%A4%E3%83%84/@35.655235,139.7522696,17z"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bp-btn"
                >
                    $ open google.maps →
                </a>
            </div>
        </div>
    </div>
</section>

<section class="bp-section">
    <div class="bp-section-inner">
        <SectionHeader no="02" en="VALUES" jp="行動指針" />
        <div class="values-grid">
            {
                values.map((v) => (
                    <article class="value-card">
                        <CornerMarks />
                        <h3>{v.jp}</h3>
                        <div class="value-en">— {v.en.toLowerCase()}</div>
                        <p>{v.d}</p>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .hl { color: var(--bp-blue); }

    .about-hero { padding-top: 64px; padding-bottom: 56px; }
    .about-hero h1 {
        font-family: var(--font-sans),serif;
        font-size: clamp(48px, 6vw, 80px);
        font-weight: 900;
        line-height: 1.02;
        color: var(--bp-ink);
        margin: 0;
        letter-spacing: -0.025em;
    }
    .about-lead {
        font-family: var(--font-sans),serif;
        font-size: 17px;
        line-height: 1.85;
        color: var(--bp-ink-soft);
        margin: 32px 0 0;
        max-width: 720px;
    }

    .about-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 24px;
    }
    @media (max-width: 800px) {
        .about-grid { grid-template-columns: 1fr; }
    }
    .bp-card-bordered {
        border: 1.5px solid var(--bp-ink);
        background: var(--bp-paper);
        padding: 32px;
        position: relative;
    }

    .spec-table {
        width: 100%;
        font-family: var(--font-mono),serif;
        font-size: 13px;
        border-collapse: collapse;
        color: var(--bp-ink);
    }
    .spec-table tr { border-top: 1px dashed var(--bp-border-dash); }
    .spec-table td {
        padding: 14px 0;
        vertical-align: top;
    }
    .spec-table .k {
        color: var(--bp-muted);
        width: 90px;
        letter-spacing: 0.08em;
    }
    .spec-table .ja {
        color: var(--bp-blue);
        width: 90px;
        font-family: var(--font-sans),serif;
        font-weight: 700;
        padding-right: 8px;
    }
    .spec-table td:last-child {
        font-family: var(--font-sans),serif;
        font-size: 14px;
        line-height: 1.7;
        letter-spacing: 0.02em;
    }

    .access-row {
        padding: 16px 0;
        border-top: 1px dashed var(--bp-border-dash);
        display: grid;
        grid-template-columns: 28px 1fr auto;
        gap: 12px;
        align-items: baseline;
    }
    .access-row[data-first="true"] { border-top: 1.5px solid var(--bp-ink); }
    .access-row[data-last="true"] { border-bottom: 1.5px solid var(--bp-ink); }
    .access-no {
        font-family: var(--font-mono),serif;
        font-size: 11px;
        color: var(--bp-blue);
        letter-spacing: 0.08em;
    }
    .access-line {
        font-family: var(--font-mono),serif;
        font-size: 11px;
        color: var(--bp-muted);
        letter-spacing: 0.08em;
        margin-bottom: 4px;
    }
    .access-stn {
        font-family: var(--font-sans),serif;
        font-size: 17px;
        font-weight: 900;
        color: var(--bp-ink);
        letter-spacing: -0.01em;
    }
    .access-exit {
        font-family: var(--font-sans),serif;
        font-weight: 400;
        font-size: 13px;
        color: var(--bp-muted);
    }
    .access-min {
        font-family: var(--font-mono),serif;
        font-size: 12px;
        color: var(--bp-blue);
        letter-spacing: 0.06em;
        font-weight: 700;
    }

    .map-container {
        border: 1.5px solid var(--bp-ink);
        height: 380px;
        position: relative;
        overflow: hidden;
        background: var(--bp-paper);
    }
    .map-cta {
        position: absolute;
        bottom: 16px;
        right: 16px;
        z-index: 1;
    }
    .map-cta .bp-btn {
        padding: 10px 18px;
        font-size: 12px;
    }

    /* Values */
    .values-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
    }
    @media (max-width: 900px) {
        .values-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 500px) {
        .values-grid { grid-template-columns: 1fr; }
    }
    .value-card {
        border: 1.5px solid var(--bp-ink);
        background: var(--bp-paper);
        padding: 24px;
        position: relative;
        min-height: 280px;
    }
    .value-card h3 {
        font-family: var(--font-sans),serif;
        font-size: 26px;
        font-weight: 900;
        color: var(--bp-ink);
        margin: 0 0 6px;
        letter-spacing: -0.015em;
    }
    .value-en {
        font-family: var(--font-mono),serif;
        font-size: 11px;
        color: var(--bp-muted);
        letter-spacing: 0.08em;
        margin-bottom: 18px;
    }
    .value-card p {
        font-family: var(--font-sans),serif;
        font-size: 13px;
        line-height: 1.85;
        color: var(--bp-ink-soft);
        margin: 0;
    }
</style>
