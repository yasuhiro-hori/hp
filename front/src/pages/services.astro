---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/react/Navbar";
import ProductsSection from "../components/astro/sections/Products.astro";
import BackendTemplates from "../components/react/BackendTemplates";
import SectionHeader from "../components/astro/shared/SectionHeader.astro";
import Contact from "../components/astro/sections/Contact.astro";
import Footer from "../layouts/Footer.astro";
import "../styles/globals.css";
---

<Layout title="ソリューション | 株式会社テクシズ">
    <Navbar client:load />
    <main>
        <ProductsSection />

        <section id="backend-templates" class="bp-section">
            <div class="bp-section-inner">
                <SectionHeader no="04" en="BACKEND TEMPLATES" jp="基盤テンプレート" />
                <BackendTemplates client:load />
            </div>
        </section>

        <Contact />
    </main>
    <Footer />
</Layout>
