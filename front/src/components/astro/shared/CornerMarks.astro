---
// Four corner crosshair marks (+) for blueprint cards
---
<span class="bp-corners" aria-hidden="true">
  <span>+</span>
  <span>+</span>
  <span>+</span>
  <span>+</span>
</span>

<style>
  .bp-corners {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .bp-corners span {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--bp-ink);
    opacity: 0.55;
    letter-spacing: 0.12em;
  }
  .bp-corners span:nth-child(1) { top: 6px; left: 8px; }
  .bp-corners span:nth-child(2) { top: 6px; right: 8px; }
  .bp-corners span:nth-child(3) { bottom: 2px; left: 8px; }
  .bp-corners span:nth-child(4) { bottom: 2px; right: 8px; }
</style>
