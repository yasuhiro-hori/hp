<section
    class="section"
    id="contact"
    style="text-align: center; margin-bottom: 4rem;"
>
    <h2>お問い合わせ</h2>
    <p style="margin-bottom: 3rem; color: var(--text-secondary);">
        お仕事のご相談・ご依頼など、お気軽にお問い合わせください。
    </p>

    <div class="contact-container">
        <form
            action="https://formspree.io/f/mkokglwj"
            method="POST"
            class="contact-form"
        >
            <div class="form-group">
                <label for="name">お名前</label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    placeholder="山田 太郎"
                    required
                />
            </div>

            <div class="form-group">
                <label for="email">メールアドレス</label>
                <input
                    type="email"
                    id="email"
                    name="_replyto"
                    placeholder="example@mail.com"
                    required
                />
            </div>

            <div class="form-group">
                <label for="message">メッセージ</label>
                <textarea
                    id="message"
                    name="message"
                    rows="5"
                    placeholder="お問い合わせ内容をご入力ください"
                    required></textarea>
            </div>

            <!-- スパム対策用のハニポットフィールド（非表示） -->
            <input type="text" name="_gotcha" style="display:none" />

            <button type="submit" class="cta-button submit-btn">
                メッセージを送信する
            </button>
        </form>
    </div>
</section>

<style>
    .contact-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 2.5rem;
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid var(--card-border);
        border-radius: 1.5rem;
        box-shadow: var(--shadow-lg);
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        text-align: left;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-color);
    }

    .form-group input,
    .form-group textarea {
        padding: 0.8rem 1rem;
        background: var(--bg-color);
        border: 1px solid var(--card-border);
        border-radius: 0.75rem;
        color: var(--text-color);
        font-family: var(--font-main);
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .submit-btn {
        width: 100%;
        border: none;
        cursor: pointer;
        padding: 1rem;
        font-size: 1rem;
        margin-top: 1rem;
        background: linear-gradient(
            135deg,
            var(--primary-color),
            var(--secondary-color)
        );
    }

    .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -10px rgba(37, 99, 235, 0.5);
    }

    @media (max-width: 640px) {
        .contact-container {
            padding: 1.5rem;
        }
    }
</style>
