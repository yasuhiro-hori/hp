---
import CornerMarks from "../shared/CornerMarks.astro";
---

<section id="contact" class="contact-section bp-grid-bg">
    <div class="contact-inner">
        <div class="contact-card">
            <CornerMarks />
            <h2>
                現場の話、<br />聞かせてください。
            </h2>
            <p class="contact-lead">
                要件が固まっていなくても構いません。<br />
                「こういうことができたら」というレベルから、一緒に考えます。
            </p>

            <form
                action="https://formspree.io/f/mkokglwj"
                method="POST"
                class="contact-form"
            >
                <div class="bp-form-group">
                    <label for="contact-name">お名前</label>
                    <input
                        type="text"
                        id="contact-name"
                        name="name"
                        placeholder="山田 太郎"
                        required
                    />
                </div>

                <div class="bp-form-group">
                    <label for="contact-email">メールアドレス</label>
                    <input
                        type="email"
                        id="contact-email"
                        name="_replyto"
                        placeholder="example@mail.com"
                        required
                    />
                </div>

                <div class="bp-form-group">
                    <label for="contact-message">メッセージ</label>
                    <textarea
                        id="contact-message"
                        name="message"
                        rows="5"
                        placeholder="お問い合わせ内容をご入力ください"
                        required></textarea>
                </div>

                <!-- スパム対策用のハニポット -->
                <input type="text" name="_gotcha" style="display:none" />

                <button type="submit" class="bp-btn bp-btn-block submit-btn">
                    $ submit --inquiry
                </button>
            </form>
        </div>
    </div>
</section>

<style>
    .contact-section {
        background-color: var(--bp-paper);
        padding: 120px 48px;
        border-bottom: 1.5px solid var(--bp-ink);
    }

    .contact-inner {
        max-width: 780px;
        margin: 0 auto;
    }

    .contact-card {
        position: relative;
        border: 1.5px solid var(--bp-ink);
        background: var(--bp-paper);
        padding: 48px;
        text-align: center;
    }
    @media (max-width: 600px) {
        .contact-section { padding: 64px 20px; }
        .contact-card { padding: 32px 20px; }
    }

    .contact-no {
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.18em;
        color: var(--bp-blue);
        margin-bottom: 16px;
    }

    .contact-card h2 {
        font-family: var(--font-sans);
        font-size: clamp(36px, 5vw, 56px);
        font-weight: 900;
        color: var(--bp-ink);
        margin: 0 0 16px;
        letter-spacing: -0.025em;
        line-height: 1.1;
    }

    .contact-lead {
        font-family: var(--font-sans);
        font-size: 15px;
        color: var(--bp-ink-soft);
        margin-bottom: 36px;
        line-height: 1.85;
    }

    .contact-form {
        text-align: left;
        margin-top: 8px;
    }

    .submit-btn {
        margin-top: 12px;
    }
</style>
