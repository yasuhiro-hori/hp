---
const steps = [
    {
        title: "現場に入る",
        desc: "まず顧客の現場に入り込み、業務の実態と課題を自分たちで掴みます。要件書を受け取るのではなく、一緒に問題を定義するところから始めます。",
    },
    {
        title: "動くものを最速で作る",
        desc: "自社テンプレートとAI活用の開発フローで、議論より先に動くプロトタイプを作ります。早く触れて初めて見えてくることを、一緒に発見します。",
    },
    {
        title: "伴走しながら育てる",
        desc: "リリースはゴールではなく、スタートです。現場の反応を見ながら継続的に改善し、使われるプロダクトへと育てていきます。",
    },
];
---

<section class="section" id="workflow">
    <h2>開発の流れ</h2>
    <div class="workflow-container">
        {
            steps.map((step, idx) => (
                <div class="workflow-step">
                    <div class="step-number">{idx + 1}</div>
                    <div class="step-content">
                        <h3>{step.title}</h3>
                        <p>{step.desc}</p>
                    </div>
                </div>
            ))
        }
    </div>
</section>
